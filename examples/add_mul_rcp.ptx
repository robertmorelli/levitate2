.version 4.1
.target sm_52
.address_size 64

// out = rcp(a + b) * c
.visible .func add_mul_rcp(
  .param .b64 p0,
  .param .b64 p1,
  .param .b64 p2,
  .param .b64 p3
)
{
  .reg .b32 %r<7>;
  .reg .b64 %rd<5>;

  ld.param.b64 %rd1, [p0];
  ld.global.b32 %r1, [%rd1];
  ld.param.b64 %rd2, [p1];
  ld.global.b32 %r2, [%rd2];
  ld.param.b64 %rd3, [p2];
  ld.global.b32 %r3, [%rd3];
  ld.param.b64 %rd4, [p3];
  add.rn.f32 %r4, %r1, %r2;
  rcp.rn.f32 %r5, %r4;
  mul.rn.f32 %r6, %r5, %r3;
  st.global.b32 [%rd4], %r6;
  ret;
}
