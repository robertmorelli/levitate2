.version 4.1
.target sm_52
.address_size 64

// out = 1 / a
.visible .func rcp_only(
  .param .b64 p0,
  .param .b64 p1
)
{
  .reg .b32 %r<3>;
  .reg .b64 %rd<3>;

  ld.param.b64 %rd1, [p0];
  ld.global.b32 %r1, [%rd1];
  ld.param.b64 %rd2, [p1];
  rcp.rn.f32 %r2, %r1;
  st.global.b32 [%rd2], %r2;
  ret;
}
