.version 4.1
.target sm_52
.address_size 64

// out = (1/a) * b
.visible .func mul_rcp(
  .param .b64 p0,
  .param .b64 p1,
  .param .b64 p2
)
{
  .reg .b32 %r<5>;
  .reg .b64 %rd<4>;

  ld.param.b64 %rd1, [p0];
  ld.global.b32 %r1, [%rd1];
  ld.param.b64 %rd2, [p1];
  ld.global.b32 %r2, [%rd2];
  ld.param.b64 %rd3, [p2];
  rcp.rn.f32 %r3, %r1;
  mul.rn.f32 %r4, %r3, %r2;
  st.global.b32 [%rd3], %r4;
  ret;
}
