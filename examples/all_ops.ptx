.version 4.1
.target sm_52
.address_size 64

// out = 1 / (fma(a, b, c) + a * b)  -- uses all 4 compute ops
.visible .func all_ops(
  .param .b64 p0,
  .param .b64 p1,
  .param .b64 p2,
  .param .b64 p3
)
{
  .reg .b32 %r<8>;
  .reg .b64 %rd<5>;

  ld.param.b64 %rd1, [p0];
  ld.global.b32 %r1, [%rd1];
  ld.param.b64 %rd2, [p1];
  ld.global.b32 %r2, [%rd2];
  ld.param.b64 %rd3, [p2];
  ld.global.b32 %r3, [%rd3];
  ld.param.b64 %rd4, [p3];
  fma.rn.f32 %r4, %r1, %r2, %r3;
  mul.rn.f32 %r5, %r1, %r2;
  add.rn.f32 %r6, %r4, %r5;
  rcp.rn.f32 %r7, %r6;
  st.global.b32 [%rd4], %r7;
  ret;
}
